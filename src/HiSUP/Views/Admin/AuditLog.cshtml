@model List<HiSUP.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Logs — HiSUP";
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">ADMIN / AUDIT LOGS</span>
        <h1 class="page-title">System Audit Logs</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Transactional change records captured by database triggers — last 100 entries.
        </p>
    </div>

    <div class="page-body">
        <div class="portal-table-wrap">
            <div class="portal-table-head">
                <span class="portal-table-head-title">Audit Trail</span>
                @if (Model != null)
                {
                    <span class="badge-role">@Model.Count ENTRIES</span>
                }
            </div>
            <div class="table-responsive">
                <table class="portal-table" id="auditTable">
                    <thead>
                        <tr>
                            <th style="padding-left:24px;">Log ID</th>
                            <th>Table</th>
                            <th>Action</th>
                            <th>Old Values</th>
                            <th>New Values</th>
                            <th>Changed By</th>
                            <th style="padding-right:24px;">Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="7" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                    No audit logs found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var log in Model)
                            {
                                <tr>
                                    <td style="padding-left:24px;" class="mono" style="color:var(--clr-muted); font-size:12px;">@log.AuditLogID</td>
                                    <td>
                                        <span class="badge-role" style="font-size:9px;">@log.TableName</span>
                                    </td>
                                    <td>
                                        @if (log.ActionType == "INSERT")
                                        {
                                            <span class="status-badge status-active">INSERT</span>
                                        }
                                        else if (log.ActionType == "UPDATE")
                                        {
                                            <span class="status-badge status-warning">UPDATE</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-danger">DELETE</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="mono" style="font-size:11px; color:var(--clr-muted); max-width:220px; display:inline-block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:middle;">
                                            @log.OldValues
                                        </span>
                                    </td>
                                    <td>
                                        <span class="mono" style="font-size:11px; color:var(--clr-text); max-width:220px; display:inline-block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:middle;">
                                            @log.NewValues
                                        </span>
                                    </td>
                                    <td style="font-size:13px; color:var(--clr-muted);">@log.ChangedBy</td>
                                    <td style="padding-right:24px;" class="mono" style="font-size:12px; color:var(--clr-muted);">
                                        @log.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
