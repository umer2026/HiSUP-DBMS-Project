@model List<HiSUP.Models.AuditLog>
@{
    ViewData["Title"] = "System Audit Logs";
}
<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;"><i
            class="bi bi-journal-text text-danger me-2"></i>System Audit Logs</h2>
            <p class="text-muted">Review transactional change records captured by database triggers.</p>
        </div>
    </div>
    <div class="card glass-card p-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover border-secondary align-middle">
                <thead>
                    <tr>
                        <th>LogID</th>
                        <th>Table Name</th>
                        <th>Action</th>
                        <th>Old Values (JSON)</th>
                        <th>New Values (JSON)</th>
                        <th>Changed By</th>
                        <th>Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-secondary py-4">No audit logs found in the system.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.AuditLogID</td>
                                <td><span class="badge bg-secondary">@log.TableName</span></td>
                                <td>
                                    @if (log.ActionType == "INSERT")
                                    {
                                        <span class="badge bg-success">INSERT</span>
                                    }
                                    else if (log.ActionType == "UPDATE")
                                    {
                                        <span class="badge bg-warning text-dark">UPDATE</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">DELETE</span>
                                    }
                                </td>
                                <td><small class="font-monospace text-secondary"
                                               style="max-width: 250px; display: inline-block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@log.OldValues</small>
                                </td>
                                <td><small class="font-monospace text-success"
                                               style="max-width: 250px; display: inline-block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@log.NewValues</small>
                                </td>
                                <td>@log.ChangedBy</td>
                                <td>@log.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
