@{
    ViewData["Title"] = "Admin Dashboard — HiSUP";
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">ADMIN / DASHBOARD</span>
        <h1 class="page-title">Administration Panel</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Manage university students, courses, and review system audit logs.
        </p>
    </div>

    <div class="page-body">

        <!-- Stats Row -->
        <div class="row g-2 mb-4">
            <div class="col-md-3">
                <div class="stat-card-dark">
                    <span class="stat-card-title">Total Students</span>
                    <span class="stat-card-value">@ViewBag.TotalStudents</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card-dark">
                    <span class="stat-card-title">Faculty Members</span>
                    <span class="stat-card-value">@ViewBag.TotalFaculty</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card-dark">
                    <span class="stat-card-title">Total Courses</span>
                    <span class="stat-card-value">@ViewBag.TotalCourses</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card-dark">
                    <span class="stat-card-title">Audit Log Entries</span>
                    <span class="stat-card-value">@ViewBag.TotalAuditLogs</span>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row g-2">
            <div class="col-md-4">
                <a asp-controller="Admin" asp-action="Students" class="action-card" id="adminStudentsCard">
                    <span class="action-card-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </span>
                    <span class="action-card-title">Search Students</span>
                    <span class="action-card-desc">Dynamic stored-procedure powered student search with CGPA, program and status filters.</span>
                    <span class="btn-ghost" style="margin-top:16px; font-size:13px; padding:8px 16px; display:inline-block;">Open &rarr;</span>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Admin" asp-action="AuditLogs" class="action-card" id="adminAuditCard">
                    <span class="action-card-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    </span>
                    <span class="action-card-title">Audit Logs</span>
                    <span class="action-card-desc">View all database-level INSERT/UPDATE/DELETE transactions captured by SQL triggers.</span>
                    <span class="btn-ghost" style="margin-top:16px; font-size:13px; padding:8px 16px; display:inline-block;">View Logs &rarr;</span>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Library" asp-action="Index" class="action-card" id="adminLibraryCard">
                    <span class="action-card-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                    </span>
                    <span class="action-card-title">Library System</span>
                    <span class="action-card-desc">View overdue books, manage catalog and issue/return tracking via SQL views.</span>
                    <span class="btn-ghost" style="margin-top:16px; font-size:13px; padding:8px 16px; display:inline-block;">Open &rarr;</span>
                </a>
            </div>
        </div>

    </div>
</div>
