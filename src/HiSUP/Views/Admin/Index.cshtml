@{
    ViewData["Title"] = "Admin Panel";
}

<!-- Header -->
<div class="row mb-4">
    <div class="col-12">
        <div class="glass-card p-4 d-flex align-items-center justify-content-between">
            <div>
                <h1 class="fw-bold mb-1" style="font-family:'Outfit',sans-serif;">
                    <i class="bi bi-shield-lock-fill me-2 text-primary"></i>Administration Panel
                </h1>
                <p class="text-muted mb-0">Manage university students, courses, and review system audit logs.</p>
            </div>
            <span class="badge badge-premium px-3 py-2 fs-6">
                <i class="bi bi-person-gear me-1"></i>Administrator
            </span>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="glass-card p-4 text-center">
            <div class="text-primary fs-1 mb-2"><i class="bi bi-people-fill"></i></div>
            <h5 class="text-muted fw-semibold mb-1">Total Students</h5>
            <h2 class="display-5 fw-bold text-light mb-0">@ViewBag.TotalStudents</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-card p-4 text-center">
            <div class="text-success fs-1 mb-2"><i class="bi bi-person-workspace"></i></div>
            <h5 class="text-muted fw-semibold mb-1">Faculty Members</h5>
            <h2 class="display-5 fw-bold text-light mb-0">@ViewBag.TotalFaculty</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-card p-4 text-center">
            <div class="text-warning fs-1 mb-2"><i class="bi bi-journal-bookmark-fill"></i></div>
            <h5 class="text-muted fw-semibold mb-1">Total Courses</h5>
            <h2 class="display-5 fw-bold text-light mb-0">@ViewBag.TotalCourses</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="glass-card p-4 text-center">
            <div class="text-danger fs-1 mb-2"><i class="bi bi-journal-text"></i></div>
            <h5 class="text-muted fw-semibold mb-1">Audit Log Entries</h5>
            <h2 class="display-5 fw-bold text-light mb-0">@ViewBag.TotalAuditLogs</h2>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-4">
    <div class="col-md-4">
        <a asp-controller="Admin" asp-action="Students" class="text-decoration-none">
            <div class="glass-card p-4 text-center h-100">
                <i class="bi bi-person-search fs-1 text-info mb-3 d-block"></i>
                <h5 class="fw-bold">Search Students</h5>
                <p class="text-muted small">Dynamic stored-procedure powered student search with CGPA, program and status filters.</p>
                <span class="btn btn-gradient btn-sm mt-2 px-4">Open</span>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Admin" asp-action="AuditLogs" class="text-decoration-none">
            <div class="glass-card p-4 text-center h-100">
                <i class="bi bi-journal-text fs-1 text-danger mb-3 d-block"></i>
                <h5 class="fw-bold">Audit Logs</h5>
                <p class="text-muted small">View all database-level INSERT/UPDATE/DELETE transactions captured by SQL triggers.</p>
                <span class="btn btn-gradient btn-sm mt-2 px-4">View Logs</span>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Library" asp-action="Index" class="text-decoration-none">
            <div class="glass-card p-4 text-center h-100">
                <i class="bi bi-book-fill fs-1 text-warning mb-3 d-block"></i>
                <h5 class="fw-bold">Library System</h5>
                <p class="text-muted small">View overdue books, manage catalog and issue/return tracking via SQL views.</p>
                <span class="btn btn-gradient btn-sm mt-2 px-4">Open</span>
            </div>
        </a>
    </div>
</div>
