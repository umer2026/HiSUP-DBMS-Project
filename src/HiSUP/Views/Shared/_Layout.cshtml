<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="HiSUP - HITEC Smart University Portal. Manage academics, finances, library and more." />
    <title>@ViewData["Title"] - HiSUP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-card: rgba(30, 41, 59, 0.6);
            --glass-border: rgba(255, 255, 255, 0.08);
            --primary-accent: #6366f1;
            --primary-glow: rgba(99, 102, 241, 0.35);
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background-image:
                radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99,102,241,0.18), transparent),
                radial-gradient(ellipse 60% 40% at 80% 80%, rgba(236,72,153,0.10), transparent);
        }

        /* Glass card */
        .glass-card {
            background: var(--bg-card);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }
        .glass-card:hover {
            transform: translateY(-4px);
            border-color: rgba(99, 102, 241, 0.3);
            box-shadow: 0 12px 40px 0 rgba(99, 102, 241, 0.2);
        }

        /* Navigation */
        .glass-nav {
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--glass-border);
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .navbar-brand {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            letter-spacing: 1px;
            background: linear-gradient(to right, #818cf8, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 1.5rem;
        }

        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 600;
            transition: all 0.2s ease;
            padding: 0.5rem 1rem !important;
            border-radius: 8px;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--text-main) !important;
            background: rgba(255, 255, 255, 0.06);
        }

        /* Buttons */
        .btn-gradient {
            background: linear-gradient(135deg, var(--primary-accent) 0%, #4f46e5 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 0.6rem 1.5rem;
            border-radius: 10px;
            box-shadow: 0 4px 14px 0 var(--primary-glow);
            transition: all 0.3s ease;
        }
        .btn-gradient:hover {
            background: linear-gradient(135deg, #4f46e5 0%, #3730a3 100%);
            transform: scale(1.03);
            box-shadow: 0 6px 20px 0 rgba(99, 102, 241, 0.5);
            color: white;
        }

        /* Badges */
        .badge-premium {
            background: rgba(99, 102, 241, 0.2);
            border: 1px solid var(--primary-accent);
            color: #a5b4fc;
            font-weight: 600;
            border-radius: 6px;
        }

        /* Animations */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-in { animation: fadeIn 0.5s ease forwards; }

        /* Alerts */
        .alert-success-glass {
            background: rgba(34, 197, 94, 0.15);
            border: 1px solid rgba(34, 197, 94, 0.4);
            color: #86efac;
            border-radius: 12px;
        }
        .alert-danger-glass {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.4);
            color: #fca5a5;
            border-radius: 12px;
        }

        /* Tables */
        .table-dark { --bs-table-bg: transparent; }
        .table-dark thead th {
            color: var(--text-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--glass-border);
        }

        /* Sidebar (for portals) */
        .sidebar {
            background: rgba(15, 23, 42, 0.7);
            border-right: 1px solid var(--glass-border);
            min-height: calc(100vh - 70px);
            padding: 1.5rem 1rem;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.6rem 1rem;
            border-radius: 10px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.2s ease;
            margin-bottom: 0.25rem;
        }
        .sidebar-link:hover, .sidebar-link.active {
            background: rgba(99, 102, 241, 0.15);
            color: #a5b4fc;
        }
        .sidebar-link i { font-size: 1.1rem; }

        /* Form controls */
        .form-control, .form-select {
            background: rgba(30, 41, 59, 0.7) !important;
            border: 1px solid var(--glass-border) !important;
            color: var(--text-main) !important;
            border-radius: 10px;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary-accent) !important;
            box-shadow: 0 0 0 3px var(--primary-glow) !important;
            outline: none;
        }
        .form-control::placeholder { color: var(--text-muted); }
        .input-group-text {
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid var(--glass-border);
            color: var(--text-muted);
        }

        /* Main content */
        .main-content { padding: 2rem 1.5rem; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-dark); }
        ::-webkit-scrollbar-thumb { background: rgba(99,102,241,0.4); border-radius: 3px; }
    </style>
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg glass-nav px-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-mortarboard-fill me-1"></i>HiSUP
            </a>
            <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-shield-lock me-1"></i>Admin Panel
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Students">
                                <i class="bi bi-people me-1"></i>Students
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="AuditLogs">
                                <i class="bi bi-journal-text me-1"></i>Audit Logs
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Student"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="CourseRegistration">
                                <i class="bi bi-journal-plus me-1"></i>Registration
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Payments">
                                <i class="bi bi-credit-card me-1"></i>Payments
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Transcript">
                                <i class="bi bi-file-earmark-text me-1"></i>Transcript
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Faculty"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Faculty" asp-action="Index">
                                <i class="bi bi-person-workspace me-1"></i>My Courses
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Finance"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Finance" asp-action="Index">
                                <i class="bi bi-cash-stack me-1"></i>Finance
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Finance" asp-action="Defaulters">
                                <i class="bi bi-exclamation-triangle me-1"></i>Defaulters
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Library" asp-action="Index">
                            <i class="bi bi-book me-1"></i>Library
                        </a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="text-secondary small me-2">
                            <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                        </span>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-gradient btn-sm px-4">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="container-fluid px-4 pt-3">
            <div class="alert alert-success-glass d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="container-fluid px-4 pt-3">
            <div class="alert alert-danger-glass d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
            </div>
        </div>
    }

    <!-- Main Content -->
    <main class="main-content fade-in">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="border-top border-secondary border-opacity-25 py-3 mt-4">
        <div class="container-fluid text-center text-muted small">
            &copy; 2026 <strong class="text-light">HiSUP</strong> &mdash; HITEC Smart University Portal &mdash; All rights reserved.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
