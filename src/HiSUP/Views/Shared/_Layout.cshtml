<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="HiSUP — HITEC Smart University Portal. Manage academics, finances, library and more." />
    <!-- Cache control -->
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>@ViewData["Title"] — HiSUP</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <!-- Bootstrap (grid/table scaffold only — all colors overridden) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- ===== TOP NAVBAR ===== -->
    <nav class="site-nav" id="siteNav" role="navigation" aria-label="Main navigation">
        <div class="nav-inner">

            <!-- LEFT: Logotype -->
            <a href="/" class="nav-logo" aria-label="HiSUP Home">
                HiSUP<span class="nav-logo-dot" aria-hidden="true"></span>
            </a>

            <!-- CENTER: Public nav links (visible only when NOT authenticated) -->
            @if (!User.Identity!.IsAuthenticated)
            {
                <ul class="nav-links" id="navLinks" role="list">
                    <li><a href="/" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">Home</a></li>
                    <li><a href="/#about" class="nav-link">About</a></li>
                    <li><a href="/#portals" class="nav-link">Portal</a></li>
                </ul>
            }
            else
            {
                <!-- Authenticated: role-based nav links -->
                <ul class="nav-links" id="navLinks" role="list">
                    @if (User.IsInRole("Admin"))
                    {
                        <li><a asp-controller="Admin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Dashboard</a></li>
                        <li><a asp-controller="Admin" asp-action="Students" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Students" ? "active" : "")">Students</a></li>
                        <li><a asp-controller="Admin" asp-action="AuditLogs" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")">Audit Logs</a></li>
                    }
                    @if (User.IsInRole("Student"))
                    {
                        <li><a asp-controller="Student" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Dashboard</a></li>
                        <li><a asp-controller="Student" asp-action="CourseRegistration" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "CourseRegistration" ? "active" : "")">Courses</a></li>
                        <li><a asp-controller="Student" asp-action="Payments" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Payments" ? "active" : "")">Payments</a></li>
                        <li><a asp-controller="Student" asp-action="Transcript" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Transcript" ? "active" : "")">Transcript</a></li>
                    }
                    @if (User.IsInRole("Faculty"))
                    {
                        <li><a asp-controller="Faculty" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Faculty" ? "active" : "")">My Courses</a></li>
                    }
                    @if (User.IsInRole("Finance"))
                    {
                        <li><a asp-controller="Finance" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Finance" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Finance</a></li>
                        <li><a asp-controller="Finance" asp-action="Defaulters" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Defaulters" ? "active" : "")">Defaulters</a></li>
                    }
                    <li><a asp-controller="Library" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Library" ? "active" : "")">Library</a></li>
                </ul>
            }

            <!-- RIGHT: Auth controls -->
            <div class="nav-right">
                @{
                    string role = "USER";
                    if (User.IsInRole("Admin")) role = "ADMIN";
                    else if (User.IsInRole("Student")) role = "STUDENT";
                    else if (User.IsInRole("Faculty")) role = "FACULTY";
                    else if (User.IsInRole("Finance")) role = "FINANCE";
                }
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="badge-role">@role</span>
                    <span class="nav-username" title="@User.Identity.Name">@User.Identity.Name</span>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline" id="logoutForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-ghost nav-logout-btn">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login" class="btn-ghost" id="navLoginBtn">Login</a>
                    <a asp-controller="Auth" asp-action="Register" class="btn-primary-yellow" id="navRegisterBtn">Register</a>
                }
            </div>

            <!-- Hamburger (mobile) -->
            <button class="nav-hamburger" id="navHamburger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobileOverlay">
                <span></span>
                <span></span>
                <span></span>
            </button>

        </div>
    </nav>

    <!-- ===== MOBILE OVERLAY ===== -->
    <div class="mobile-overlay" id="mobileOverlay" role="dialog" aria-modal="true" aria-label="Mobile navigation">
        <button class="mobile-overlay-close" id="mobileClose" aria-label="Close navigation menu">✕</button>
        <nav class="mobile-nav" role="navigation">
            @if (!User.Identity.IsAuthenticated)
            {
                <a href="/" class="mobile-nav-link">Home</a>
                <a href="/#about" class="mobile-nav-link">About</a>
                <a href="/#portals" class="mobile-nav-link">Portal</a>
                <div class="mobile-nav-divider"></div>
                <a asp-controller="Auth" asp-action="Login" class="mobile-nav-link mobile-nav-cta">Login</a>
                <a asp-controller="Auth" asp-action="Register" class="mobile-nav-link mobile-nav-cta-yellow">Register</a>
            }
            else
            {
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index" class="mobile-nav-link">Dashboard</a>
                    <a asp-controller="Admin" asp-action="Students" class="mobile-nav-link">Students</a>
                    <a asp-controller="Admin" asp-action="AuditLogs" class="mobile-nav-link">Audit Logs</a>
                }
                @if (User.IsInRole("Student"))
                {
                    <a asp-controller="Student" asp-action="Index" class="mobile-nav-link">Dashboard</a>
                    <a asp-controller="Student" asp-action="CourseRegistration" class="mobile-nav-link">Courses</a>
                    <a asp-controller="Student" asp-action="Payments" class="mobile-nav-link">Payments</a>
                    <a asp-controller="Student" asp-action="Transcript" class="mobile-nav-link">Transcript</a>
                }
                @if (User.IsInRole("Faculty"))
                {
                    <a asp-controller="Faculty" asp-action="Index" class="mobile-nav-link">My Courses</a>
                }
                @if (User.IsInRole("Finance"))
                {
                    <a asp-controller="Finance" asp-action="Index" class="mobile-nav-link">Finance</a>
                    <a asp-controller="Finance" asp-action="Defaulters" class="mobile-nav-link">Defaulters</a>
                }
                <a asp-controller="Library" asp-action="Index" class="mobile-nav-link">Library</a>
                <div class="mobile-nav-divider"></div>
                <form asp-controller="Auth" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="mobile-nav-link mobile-nav-logout">Logout</button>
                </form>
            }
        </nav>
    </div>

    <!-- ===== FLASH MESSAGES ===== -->
    @if (TempData["Success"] != null)
    {
        <div class="flash-bar flash-success" role="alert" aria-live="polite">
            <span class="flash-icon">✓</span>
            <span>@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="flash-bar flash-error" role="alert" aria-live="assertive">
            <span class="flash-icon">✕</span>
            <span>@TempData["Error"]</span>
        </div>
    }

    <!-- ===== MAIN CONTENT ===== -->
    <main class="site-main" id="mainContent">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="site-footer" role="contentinfo">
        <span class="mono">HITEC University &copy; 2025 &nbsp;&middot;&nbsp; HiSUP Portal</span>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Mobile nav toggle -->
    <script>
        (function () {
            var hamburger = document.getElementById('navHamburger');
            var overlay = document.getElementById('mobileOverlay');
            var close = document.getElementById('mobileClose');

            function openMenu() {
                overlay.classList.add('is-open');
                hamburger.classList.add('is-active');
                hamburger.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';
            }

            function closeMenu() {
                overlay.classList.remove('is-open');
                hamburger.classList.remove('is-active');
                hamburger.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
            }

            if (hamburger) hamburger.addEventListener('click', openMenu);
            if (close) close.addEventListener('click', closeMenu);

            // Close on overlay click outside nav
            if (overlay) {
                overlay.addEventListener('click', function (e) {
                    if (e.target === overlay) closeMenu();
                });
            }

            // Close on ESC
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeMenu();
            });
        })();
    </script>

    <!-- Back/forward cache prevention -->
    <script>
        window.addEventListener('pageshow', function (event) {
            if (event.persisted) {
                window.location.reload();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
