@model List<HiSUP.Models.Enrollment>
@{
    ViewData["Title"] = "My Grades — HiSUP";
    int sectionId = ViewBag.SectionID;
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">STUDENT / GRADES</span>
        <h1 class="page-title">Academic Grade Entry</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Submit final marks (0–100). Database triggers auto-calculate GPA and letter grades.
        </p>
    </div>

    <div class="page-body">
        <form asp-action="SubmitGrades" method="post" id="studentGradeForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="sectionId" value="@sectionId" />

            <div class="portal-table-wrap mb-4">
                <div class="portal-table-head">
                    <span class="portal-table-head-title">Enrolled Students</span>
                </div>
                <div class="table-responsive">
                    <table class="portal-table" id="studentGradeTable">
                        <thead>
                            <tr>
                                <th style="padding-left:24px;">Student ID</th>
                                <th>Student Name</th>
                                <th>Email</th>
                                <th>Current Grade</th>
                                <th style="padding-right:24px; width:200px;">Enter Marks (0–100)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="5" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                        No enrolled students found.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                for (int i = 0; i < Model.Count; i++)
                                {
                                    var enrollment = Model[i];
                                    <tr>
                                        <td style="padding-left:24px;" class="mono" style="font-size:12px; color:var(--clr-muted);">@enrollment.StudentID</td>
                                        <td style="font-weight:600; color:var(--clr-white);">
                                            @enrollment.Student.FirstName @enrollment.Student.LastName
                                        </td>
                                        <td class="mono" style="font-size:12px; color:var(--clr-muted);">@enrollment.Student.Email</td>
                                        <td>
                                            @if (enrollment.Grade != null)
                                            {
                                                <span class="status-badge status-active">@enrollment.Grade.GradeValue (@enrollment.Grade.Marks pts)</span>
                                            }
                                            else
                                            {
                                                <span class="mono" style="font-size:11px; color:var(--clr-muted);">NOT GRADED</span>
                                            }
                                        </td>
                                        <td style="padding-right:24px;">
                                            <input type="hidden" name="gradeList[@i].EnrollmentID" value="@enrollment.EnrollmentID" />
                                            <input type="number" name="gradeList[@i].Marks"
                                                   min="0" max="100"
                                                   class="form-input"
                                                   style="padding:8px 12px;"
                                                   value="@(enrollment.Grade != null ? enrollment.Grade.Marks.ToString() : "")"
                                                   required />
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div style="display:flex; gap:12px; justify-content:flex-end;">
                    <a asp-action="Index" class="btn-ghost" style="padding:12px 24px;">Cancel</a>
                    <button type="submit" class="btn-primary-yellow" style="padding:12px 28px;" id="submitMergeBtn">
                        Submit &amp; Merge Grades
                    </button>
                </div>
            }
        </form>
    </div>
</div>
