@model List<HiSUP.Controllers.StudentSearchResultDto>
@{
    ViewData["Title"] = "Manage Students";
    var programs = ViewBag.Programs as List<HiSUP.Models.AcademicProgram>;
}
<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;"><i class="bi bi-people text-info me-2"></i>Manage
            Students</h2>
            <p class="text-muted">Perform injection-safe dynamic query searches on registered students.</p>
        </div>
    </div>
    <!-- Filters Card -->
    <div class="card glass-card p-4 mb-4">
        <form method="get" asp-action="Students">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label text-light fw-semibold">Search Name/Email</label>
                    <input type="text" name="searchTerm" class="form-control bg-transparent text-light border-secondary"
                           placeholder="Type name..." value="@Context.Request.Query["searchTerm"]" />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-light fw-semibold">Program Filter</label>
                    <select name="programId" class="form-select bg-dark text-light border-secondary">
                        <option value="">-- All Programs --</option>
                        @if (programs != null)
                        {
                            foreach (var prog in programs)
                            {
                                <option value="@prog.ProgramID"
                                        selected="@(Context.Request.Query["programId"] == prog.ProgramID.ToString())">@prog.ProgramName
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-light fw-semibold">Min CGPA</label>
                    <input type="number" name="minCGPA" step="0.01" min="0" max="4"
                           class="form-control bg-transparent text-light border-secondary" placeholder="0.00"
                           value="@Context.Request.Query["minCGPA"]" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-light fw-semibold">Status</label>
                    <select name="status" class="form-select bg-dark text-light border-secondary">
                        <option value="">-- All Statuses --</option>
                        <option value="Active" selected="@(Context.Request.Query["status"] == "Active")">Active</option>
                        <option value="Suspended" selected="@(Context.Request.Query["status"] == "Suspended")">Suspended
                        </option>
                        <option value="Graduated" selected="@(Context.Request.Query["status"] == "Graduated")">Graduated
                        </option>
                        <option value="Withdrawn" selected="@(Context.Request.Query["status"] == "Withdrawn")">Withdrawn
                        </option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-gradient w-100 py-2"><i
                        class="bi bi-search me-2"></i>Search</button>
                    </div>
                </div>
            </form>
        </div>
        <!-- Results List -->
        <div class="card glass-card p-4">
            <div class="table-responsive">
                <table class="table table-dark table-hover border-secondary align-middle">
                    <thead>
                        <tr>
                            <th>StudentID</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email</th>
                            <th>CGPA</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-secondary py-4">No student records match the search
                                    criteria.</td>
                                </tr>
                            }
                else
                            {
                                foreach (var s in Model)
                                {
                                    <tr>
                                        <td>@s.StudentID</td>
                                        <td class="text-light fw-semibold">@s.FirstName</td>
                                        <td class="text-light fw-semibold">@s.LastName</td>
                                        <td>@s.Email</td>
                                        <td class="text-info fw-bold">@s.CGPA.ToString("0.00")</td>
                                        <td>
                                            <span class="badge @(s.Status == "Active" ? "bg-success" : "bg-warning")">@s.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>