@model List<HiSUP.Models.Section>
@{
    ViewData["Title"] = "Course Registration — HiSUP";
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">STUDENT / REGISTRATION</span>
        <h1 class="page-title">Course Registration</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Enroll in available sections for the current academic semester.
        </p>
    </div>

    <div class="page-body">
        <div class="portal-table-wrap">
            <div class="portal-table-head">
                <span class="portal-table-head-title">Available Sections</span>
                @if (Model != null)
                {
                    <span class="badge-role">@Model.Count SECTIONS</span>
                }
            </div>
            <div class="table-responsive">
                <table class="portal-table" id="courseRegTable">
                    <thead>
                        <tr>
                            <th style="padding-left:24px;">Course Code</th>
                            <th>Course Title</th>
                            <th>Credits</th>
                            <th>Section</th>
                            <th>Faculty</th>
                            <th>Room</th>
                            <th>Seats</th>
                            <th style="text-align:right; padding-right:24px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="8" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                    No sections available for registration.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var sec in Model)
                            {
                                var seatsLeft = sec.Capacity - sec.EnrolledCount;
                                <tr>
                                    <td style="padding-left:24px;">
                                        <span class="badge-role" style="font-size:9px;">@sec.Course.CourseCode</span>
                                    </td>
                                    <td style="font-weight:600; color:var(--clr-white);">@sec.Course.CourseTitle</td>
                                    <td class="mono" style="font-size:13px; color:var(--clr-muted);">@sec.Course.Credits</td>
                                    <td class="mono" style="font-size:12px;">@sec.SectionName</td>
                                    <td style="font-size:13px; color:var(--clr-muted);">
                                        @(sec.Faculty != null ? $"{sec.Faculty.FirstName} {sec.Faculty.LastName}" : "TBD")
                                    </td>
                                    <td class="mono" style="font-size:12px; color:var(--clr-muted);">@sec.RoomNo</td>
                                    <td>
                                        @if (seatsLeft > 0)
                                        {
                                            <span class="mono" style="font-size:12px; color:#6fcf6f;">@seatsLeft / @sec.Capacity</span>
                                        }
                                        else
                                        {
                                            <span class="mono" style="font-size:12px; color:var(--clr-red);">FULL</span>
                                        }
                                    </td>
                                    <td style="text-align:right; padding-right:24px;">
                                        @if (seatsLeft > 0)
                                        {
                                            <form asp-action="Enroll" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="sectionId" value="@sec.SectionID" />
                                                <button type="submit" class="btn-primary-yellow" style="padding:7px 16px; font-size:12px;">
                                                    Enroll
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn-ghost" style="padding:7px 16px; font-size:12px; opacity:0.4; cursor:not-allowed;" disabled>Full</button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
