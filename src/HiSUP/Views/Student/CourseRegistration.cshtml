@model List<HiSUP.Models.Section>
@{
    ViewData["Title"] = "Course Registration";
}
<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;"><i
            class="bi bi-journal-plus me-2 text-primary"></i>Course Registration</h2>
            <p class="text-muted">Enroll in available sections for the current academic semester.</p>
        </div>
    </div>
    <div class="card glass-card p-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover border-secondary align-middle">
                <thead>
                    <tr>
                        <th>Course Code</th>
                        <th>Course Title</th>
                        <th>Credits</th>
                        <th>Section</th>
                        <th>Faculty</th>
                        <th>Room</th>
                        <th>Seats Available</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-secondary py-4">No sections available for registration.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var sec in Model)
                        {
                            var seatsLeft = sec.Capacity - sec.EnrolledCount;
                            <tr>
                                <td><span class="badge bg-secondary">@sec.Course.CourseCode</span></td>
                                <td class="fw-semibold text-light">@sec.Course.CourseTitle</td>
                                <td>@sec.Course.Credits</td>
                                <td>@sec.SectionName</td>
                                <td>@(sec.Faculty != null ? $"{sec.Faculty.FirstName} {sec.Faculty.LastName}" : "TBD")
                                </td>
                                <td>@sec.RoomNo</td>
                                <td>
                                    @if (seatsLeft > 0)
                                    {
                                        <span class="text-success">@seatsLeft / @sec.Capacity seats left</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">Full</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (seatsLeft > 0)
                                    {
                                        <form asp-action="Enroll" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="sectionId" value="@sec.SectionID" />
                                            <button type="submit" class="btn btn-gradient btn-sm">Enroll</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary btn-sm" disabled>Full</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
