@model List<HiSUP.Models.TranscriptEntryDto>
@{
    ViewData["Title"] = "Academic Transcript — HiSUP";
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">STUDENT / TRANSCRIPT</span>
        <h1 class="page-title">Academic Transcript</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            HITEC University Taxila — Official Academic Record
            <span class="mono" style="margin-left:12px; font-size:12px;">Issued: @DateTime.Now.ToString("yyyy-MM-dd")</span>
        </p>
    </div>

    <div class="page-body">

        <!-- Grade Report Table -->
        <div class="portal-table-wrap mb-4">
            <div class="portal-table-head">
                <span class="portal-table-head-title">Grade Report</span>
                @if (Model != null)
                {
                    <span class="badge-role">@Model.Count RECORDS</span>
                }
            </div>
            <div class="table-responsive">
                <table class="portal-table" id="transcriptTable">
                    <thead>
                        <tr>
                            <th style="padding-left:24px;">Semester</th>
                            <th>Course Code</th>
                            <th>Course Title</th>
                            <th>Credits</th>
                            <th>Marks</th>
                            <th>Grade</th>
                            <th>Grade Points</th>
                            <th style="text-align:right; padding-right:24px;">Sem GPA</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="8" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                    No academic results found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var entry in Model)
                            {
                                <tr>
                                    <td style="padding-left:24px;" class="mono" style="font-size:12px; color:var(--clr-muted);">
                                        @entry.Semester / @entry.Year
                                    </td>
                                    <td>
                                        <span class="badge-role" style="font-size:9px;">@entry.CourseCode</span>
                                    </td>
                                    <td style="font-size:13px; color:var(--clr-text);">@entry.CourseTitle</td>
                                    <td class="mono" style="font-size:13px; color:var(--clr-muted);">@entry.Credits</td>
                                    <td class="mono" style="font-size:13px;">@entry.Marks</td>
                                    <td>
                                        <span class="status-badge @(entry.GradeValue == "F" ? "status-danger" : entry.GradeValue == "A+" || entry.GradeValue == "A" ? "status-active" : "status-warning")">
                                            @entry.GradeValue
                                        </span>
                                    </td>
                                    <td class="mono" style="font-size:13px; color:var(--clr-text);">@entry.GradePoints.ToString("0.00")</td>
                                    <td style="text-align:right; padding-right:24px; font-weight:700; font-family:var(--font-mono); color:var(--clr-yellow);">
                                        @entry.SemGPA.ToString("0.00")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Grading Key -->
        <div class="card-dark">
            <span class="stat-card-title">Grading System Key</span>
            <div style="display:flex; gap:32px; flex-wrap:wrap; margin-top:8px;">
                <div class="mono" style="font-size:12px; color:var(--clr-muted); line-height:1.9;">
                    A+ (4.00) &nbsp;·&nbsp; A (4.00) &nbsp;·&nbsp; A- (3.70) &nbsp;·&nbsp; B+ (3.30) &nbsp;·&nbsp; B (3.00) &nbsp;·&nbsp; B- (2.70)<br />
                    C+ (2.30) &nbsp;·&nbsp; C (2.00) &nbsp;·&nbsp; C- (1.70) &nbsp;·&nbsp; D (1.00) &nbsp;·&nbsp; F (0.00)
                </div>
                <div style="margin-left:auto; font-size:12px; color:var(--clr-muted); text-align:right; line-height:1.9;">
                    Verified by: <span style="color:var(--clr-text);">HiSUP Secure DB</span><br />
                    <span class="mono" style="font-size:11px;">Digital transcript — verified under database constraints.</span>
                </div>
            </div>
        </div>

    </div>
</div>
