@model List<HiSUP.Models.FeePayment>
@{
    ViewData["Title"] = "Fee Payments";
    var structures = ViewBag.FeeStructures as List<HiSUP.Models.FeeStructure>;
}
<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;"><i
            class="bi bi-credit-card me-2 text-warning"></i>Fee Management & Payments</h2>
            <p class="text-muted">Process your semester tuition fees and review your transaction logs.</p>
        </div>
    </div>
    <div class="row g-4 mb-5">
        <!-- Payment Form -->
        <div class="col-md-5">
            <div class="card glass-card p-4">
                <h4 class="fw-bold mb-4" style="font-family: 'Outfit', sans-serif;"><i class="bi bi-wallet2 me-2"></i>Make
                    Payment</h4>
                    <form asp-action="PayFee" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label text-light fw-semibold">Select Semester Fee Schedule</label>
                            <select name="feeStructureId" class="form-select bg-dark text-light border-secondary" required>
                                @if (structures != null)
                                {
                                    foreach (var s in structures)
                                    {
                                        <option value="@s.FeeStructureID">Semester @s.Semester Fee (Total: Rs.
                                            @s.TotalAmount.ToString("N0"))</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-light fw-semibold">Amount to Pay (Rs.)</label>
                                <input type="number" name="amount" min="1" step="0.01"
                                       class="form-control bg-transparent text-light border-secondary" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-light fw-semibold">Payment Method</label>
                                <select name="paymentMethod" class="form-select bg-dark text-light border-secondary" required>
                                    <option value="Bank Transfer">Bank Transfer</option>
                                    <option value="Credit Card">Credit Card</option>
                                    <option value="Cash">Cash</option>
                                    <option value="Challan">Challan</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-light fw-semibold">Bank Account / Reference</label>
                                <input type="text" name="bankAccount"
                                       class="form-control bg-transparent text-light border-secondary"
                                       placeholder="PK00-ABCD-0000-0000-0000" required />
                            </div>
                            <button type="submit" class="btn btn-gradient w-100 py-3"><i class="bi bi-shield-check me-2"></i>Submit
                                Payment</button>
                            </form>
                        </div>
                    </div>
                    <!-- Payment History -->
                    <div class="col-md-7">
                        <div class="card glass-card p-4 h-100">
                            <h4 class="fw-bold mb-4" style="font-family: 'Outfit', sans-serif;"><i
                                class="bi bi-clock-history me-2"></i>Payment History</h4>
                                <div class="table-responsive">
                                    <table class="table table-dark table-hover border-secondary align-middle">
                                        <thead>
                                            <tr>
                                                <th>Transaction ID</th>
                                                <th>Semester</th>
                                                <th>Amount Paid</th>
                                                <th>Date</th>
                                                <th>Method</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (Model == null || !Model.Any())
                                            {
                                                <tr>
                                                    <td colspan="6" class="text-center text-secondary py-4">No payment logs found.</td>
                                                </tr>
                                            }
                                            else
                                            {
                                                foreach (var pay in Model)
                                                {
                                                    <tr>
                                                        <td><span class="text-info fw-semibold font-monospace">@pay.TransactionID</span></td>
                                                        <td>Semester @pay.FeeStructure.Semester</td>
                                                        <td class="text-success fw-bold">Rs. @pay.AmountPaid.ToString("N2")</td>
                                                        <td>@pay.PaymentDate.ToString("yyyy-MM-dd")</td>
                                                        <td>@pay.PaymentMethod</td>
                                                        <td>
                                                            @if (pay.Status == "Approved")
                                                            {
                                                                <span class="badge bg-success">Approved</span>
                                                            }
                                                            else if (pay.Status == "Pending")
                                                            {
                                                                <span class="badge bg-warning text-dark">Pending</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-danger">Rejected</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
