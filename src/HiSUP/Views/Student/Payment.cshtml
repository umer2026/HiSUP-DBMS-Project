@model List<HiSUP.Models.FeePayment>
@{
    ViewData["Title"] = "Fee Management — HiSUP";
    var structures = ViewBag.FeeStructures as List<HiSUP.Models.FeeStructure>;
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">STUDENT / PAYMENT</span>
        <h1 class="page-title">Fee Management &amp; Payments</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Process your semester tuition fees and review transaction logs.
        </p>
    </div>

    <div class="page-body">
        <div class="row g-3">

            <!-- Payment Form -->
            <div class="col-md-5">
                <div class="card-dark" style="height:100%;">
                    <span class="stat-card-title">Make Payment</span>

                    <form asp-action="PayFee" method="post" id="feePayForm" style="margin-top:20px;">
                        @Html.AntiForgeryToken()

                        <div class="form-field">
                            <label class="form-label" for="feeStructureId">Select Semester Fee Schedule</label>
                            <select name="feeStructureId" id="feeStructureId" class="form-select" required>
                                @if (structures != null)
                                {
                                    foreach (var s in structures)
                                    {
                                        <option value="@s.FeeStructureID">Semester @s.Semester (Rs. @s.TotalAmount.ToString("N0"))</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-field">
                            <label class="form-label" for="amount">Amount to Pay (Rs.)</label>
                            <input type="number" name="amount" id="amount"
                                   min="1" step="0.01"
                                   class="form-input" required placeholder="0.00" />
                        </div>

                        <div class="form-field">
                            <label class="form-label" for="paymentMethod">Payment Method</label>
                            <select name="paymentMethod" id="paymentMethod" class="form-select" required>
                                <option value="Bank Transfer">Bank Transfer</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="Cash">Cash</option>
                                <option value="Challan">Challan</option>
                            </select>
                        </div>

                        <div class="form-field">
                            <label class="form-label" for="bankAccount">Bank Account / Reference</label>
                            <input type="text" name="bankAccount" id="bankAccount"
                                   class="form-input mono"
                                   placeholder="PK00-ABCD-0000-0000-0000" required />
                        </div>

                        <button type="submit" class="btn-primary-yellow" style="width:100%; padding:13px 20px; font-size:14px;" id="submitPayBtn">
                            Submit Payment
                        </button>
                    </form>
                </div>
            </div>

            <!-- Payment History -->
            <div class="col-md-7">
                <div class="portal-table-wrap">
                    <div class="portal-table-head">
                        <span class="portal-table-head-title">Payment History</span>
                        @if (Model != null)
                        {
                            <span class="badge-role">@Model.Count TRANSACTIONS</span>
                        }
                    </div>
                    <div class="table-responsive">
                        <table class="portal-table" id="payHistoryTable">
                            <thead>
                                <tr>
                                    <th style="padding-left:24px;">Transaction ID</th>
                                    <th>Semester</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Method</th>
                                    <th style="text-align:right; padding-right:24px;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model == null || !Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                            No payment records found.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var pay in Model)
                                    {
                                        <tr>
                                            <td style="padding-left:24px;" class="mono" style="font-size:11px; color:var(--clr-muted);">@pay.TransactionID</td>
                                            <td class="mono" style="font-size:12px; color:var(--clr-muted);">SEM @pay.FeeStructure.Semester</td>
                                            <td style="font-weight:700; font-family:var(--font-mono); color:var(--clr-yellow);">Rs. @pay.AmountPaid.ToString("N2")</td>
                                            <td class="mono" style="font-size:12px; color:var(--clr-muted);">@pay.PaymentDate.ToString("yyyy-MM-dd")</td>
                                            <td style="font-size:13px; color:var(--clr-muted);">@pay.PaymentMethod</td>
                                            <td style="text-align:right; padding-right:24px;">
                                                @if (pay.Status == "Approved")
                                                {
                                                    <span class="status-badge status-active">Approved</span>
                                                }
                                                else if (pay.Status == "Pending")
                                                {
                                                    <span class="status-badge status-warning">Pending</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-danger">Rejected</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
