@model IEnumerable<HiSUP.Models.FeePayment>
@{
    ViewData["Title"] = "Fee Payments — HiSUP";
    var feeStructures = ViewBag.FeeStructures as IEnumerable<HiSUP.Models.FeeStructure>;
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">STUDENT / PAYMENTS</span>
        <h1 class="page-title">Fee Payments</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Manage your tuition fees and track payment history.
        </p>
    </div>

    <div class="page-body">

        <div class="row g-3">

            <!-- Make a Payment -->
            <div class="col-lg-4">
                <div class="card-dark" style="height:100%;">
                    <span class="stat-card-title">Make a Payment</span>

                    <form asp-controller="Student" asp-action="PayFee" method="post" id="payFeeForm" style="margin-top:20px;">
                        @Html.AntiForgeryToken()

                        <div class="form-field">
                            <label class="form-label" for="feeStructureId">Fee Structure</label>
                            <select name="feeStructureId" id="feeStructureId" class="form-select" required>
                                <option value="">— Select Fee —</option>
                                @if (feeStructures != null)
                                {
                                    foreach (var fs in feeStructures)
                                    {
                                        <option value="@fs.FeeStructureID">Semester @fs.Semester (@fs.TotalAmount.ToString("C"))</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-field">
                            <label class="form-label" for="amount">Amount to Pay (Rs.)</label>
                            <input type="number" step="0.01" name="amount" id="amount"
                                   class="form-input" required placeholder="0.00" />
                        </div>

                        <div class="form-field">
                            <label class="form-label" for="paymentMethod">Payment Method</label>
                            <select name="paymentMethod" id="paymentMethod" class="form-select" required>
                                <option value="Credit Card">Credit Card</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                                <option value="Debit Card">Debit Card</option>
                            </select>
                        </div>

                        <div class="form-field">
                            <label class="form-label" for="bankAccount">Bank Account / Card Reference</label>
                            <input type="text" name="bankAccount" id="bankAccount"
                                   class="form-input mono" required placeholder="**** **** **** 1234" />
                        </div>

                        <button type="submit" class="btn-primary-yellow" style="width:100%; padding:13px 20px; font-size:14px;" id="processPayBtn">
                            Process Payment
                        </button>
                    </form>
                </div>
            </div>

            <!-- Payment History -->
            <div class="col-lg-8">
                <div class="portal-table-wrap">
                    <div class="portal-table-head">
                        <span class="portal-table-head-title">Payment History</span>
                        @if (Model != null)
                        {
                            <span class="badge-role">@Model.Count() RECORDS</span>
                        }
                    </div>
                    <div class="table-responsive">
                        <table class="portal-table" id="paymentsHistoryTable">
                            <thead>
                                <tr>
                                    <th style="padding-left:24px;">Date</th>
                                    <th>Fee Type</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th style="padding-right:24px;">Transaction ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model == null || !Model.Any())
                                {
                                    <tr>
                                        <td colspan="5" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                            No payments yet. Your history will appear here after your first transaction.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var payment in Model.OrderByDescending(p => p.PaymentDate))
                                    {
                                        <tr>
                                            <td style="padding-left:24px;" class="mono" style="font-size:12px; color:var(--clr-muted);">
                                                @payment.PaymentDate.ToString("yyyy-MM-dd")
                                            </td>
                                            <td style="font-size:13px; color:var(--clr-text);">
                                                Semester @(payment.FeeStructure?.Semester.ToString() ?? "—")
                                            </td>
                                            <td style="font-weight:700; color:var(--clr-yellow); font-family:var(--font-mono);">
                                                Rs. @payment.AmountPaid.ToString("N2")
                                            </td>
                                            <td>
                                                <span class="badge-role" style="font-size:9px;">@payment.PaymentMethod</span>
                                            </td>
                                            <td style="padding-right:24px;" class="mono" style="font-size:11px; color:var(--clr-muted);">
                                                @payment.TransactionID
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
