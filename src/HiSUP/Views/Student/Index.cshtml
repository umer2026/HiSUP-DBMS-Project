@model HiSUP.Controllers.vw_StudentDashboardDto
@{
    ViewData["Title"] = "Student Dashboard — HiSUP";
}

@if (Model == null)
{
    <div class="portal-page">
        <div class="page-body" style="text-align:center; padding-top:80px; color:var(--clr-muted);">
            <p style="font-size:14px;">Unable to load dashboard. Please
                <a asp-controller="Auth" asp-action="Login" style="color:var(--clr-yellow);">login again</a>.
            </p>
        </div>
    </div>
    return;
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">STUDENT / DASHBOARD</span>
        <h1 class="page-title">@Model.FirstName @Model.LastName</h1>
        <p style="font-size:13px; color:var(--clr-muted); margin-top:6px; font-family:var(--font-mono);">
            @Model.ProgramName &nbsp;&middot;&nbsp; Semester @Model.CurrentSemester &nbsp;&middot;&nbsp;
            <span style="color:var(--clr-text);">@Model.Email</span>
            &nbsp;&middot;&nbsp;
            <span class="status-badge @(Model.Status == "Active" ? "status-active" : "status-warning")">@Model.Status</span>
        </p>
    </div>

    <div class="page-body">

        <!-- Key Stats -->
        <div class="row g-2 mb-4">
            <div class="col-md-4">
                <div class="stat-card-dark">
                    <span class="stat-card-title">Cumulative CGPA</span>
                    <span class="stat-card-value">@Model.CGPA.ToString("0.00")</span>
                    <div style="margin-top:4px; font-family:var(--font-mono); font-size:11px; color:var(--clr-muted);">OUT OF 4.00</div>
                    <div class="portal-progress" style="margin-top:12px;">
                        <div class="portal-progress-bar" style="width:@((Model.CGPA / 4.0m * 100).ToString("0"))%;"></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card-dark">
                    <span class="stat-card-title">Attendance Rate</span>
                    <span class="stat-card-value">@Model.AttendancePercentage.ToString("0.0")<span style="font-size:16px; font-weight:500;">%</span></span>
                    <div style="margin-top:4px; font-family:var(--font-mono); font-size:11px; color:@(Model.AttendancePercentage < 75 ? "var(--clr-red)" : "var(--clr-muted)");">
                        @(Model.AttendancePercentage < 75 ? "⚠ BELOW 75% MINIMUM" : "MIN. REQUIRED: 75%")
                    </div>
                    <div class="portal-progress" style="margin-top:12px;">
                        <div class="portal-progress-bar @(Model.AttendancePercentage < 75 ? "bar-red" : "bar-green")"
                             style="width:@Model.AttendancePercentage.ToString("0")%;"></div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card-dark" style="border-left-color:@(Model.OutstandingFee > 0 ? "var(--clr-red)" : "var(--clr-yellow)");">
                    <span class="stat-card-title">Outstanding Balance</span>
                    <span class="stat-card-value" style="font-size:22px;">Rs. @Model.OutstandingFee.ToString("N0")</span>
                    <div style="margin-top:4px; font-family:var(--font-mono); font-size:11px; color:@(Model.OutstandingFee > 0 ? "var(--clr-red)" : "var(--clr-muted)");">
                        @(Model.OutstandingFee > 0 ? "PAYMENT REQUIRED" : "NO DUES OUTSTANDING")
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div style="margin-bottom:16px;">
            <span class="section-label">QUICK ACTIONS</span>
        </div>
        <div class="row g-2">
            <div class="col-md-3">
                <a asp-controller="Student" asp-action="CourseRegistration" class="action-card" id="studentCourseCard">
                    <span class="action-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                    </span>
                    <span class="action-card-title">Course Registration</span>
                    <span class="action-card-desc">Enroll in available sections for the current semester.</span>
                </a>
            </div>
            <div class="col-md-3">
                <a asp-controller="Student" asp-action="Payments" class="action-card" id="studentPayCard">
                    <span class="action-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                    </span>
                    <span class="action-card-title">Pay Fees</span>
                    <span class="action-card-desc">Submit fee payments securely through the portal.</span>
                </a>
            </div>
            <div class="col-md-3">
                <a asp-controller="Student" asp-action="Transcript" class="action-card" id="studentTranscriptCard">
                    <span class="action-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                    </span>
                    <span class="action-card-title">Academic Transcript</span>
                    <span class="action-card-desc">View your complete grade history and CGPA breakdown.</span>
                </a>
            </div>
            <div class="col-md-3">
                <a asp-controller="Library" asp-action="Index" class="action-card" id="studentLibraryCard">
                    <span class="action-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                    </span>
                    <span class="action-card-title">Library</span>
                    <span class="action-card-desc">Search &amp; browse the library catalog.</span>
                </a>
            </div>
        </div>

    </div>
</div>
