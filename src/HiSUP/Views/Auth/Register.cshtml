@{
    ViewData["Title"] = "Create Account — HiSUP";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card" style="max-width: 500px;">

        <!-- Logotype -->
        <div class="auth-logo" aria-label="HiSUP">
            HiSUP<span class="auth-logo-dot" aria-hidden="true"></span>
        </div>

        <h1 class="auth-heading">Create Account</h1>
        <p class="auth-sub">Register a new student account on the HiSUP portal.</p>

        @if (!ViewContext.ModelState.IsValid)
        {
            <div class="auth-alert auth-alert-error" role="alert">
                <span class="auth-alert-icon">✕</span>
                <div asp-validation-summary="ModelOnly" style="margin:0;"></div>
            </div>
        }

        <form asp-controller="Auth" asp-action="Register" method="post" id="registerForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="reg-row">
                <div class="form-field">
                    <label class="form-label" for="regFirstName">First Name</label>
                    <input type="text" name="firstName" id="regFirstName"
                           class="form-input" required placeholder="Muhammad" />
                </div>
                <div class="form-field">
                    <label class="form-label" for="regLastName">Last Name</label>
                    <input type="text" name="lastName" id="regLastName"
                           class="form-input" required placeholder="Ali" />
                </div>
            </div>

            <div class="reg-row">
                <div class="form-field">
                    <label class="form-label" for="regEmail">Email Address</label>
                    <input type="email" name="email" id="regEmail"
                           class="form-input" required placeholder="student@hitec.edu.pk" />
                </div>
                <div class="form-field">
                    <label class="form-label" for="regPhone">Phone Number</label>
                    <input type="text" name="phone" id="regPhone"
                           class="form-input" placeholder="0300-1234567" />
                </div>
            </div>

            <div class="reg-row">
                <div class="form-field">
                    <label class="form-label" for="regCNIC">CNIC</label>
                    <input type="text" name="cnic" id="regCNIC"
                           class="form-input mono" required placeholder="37405-1234567-1" />
                </div>
                <div class="form-field">
                    <label class="form-label" for="regDob">Date of Birth</label>
                    <input type="date" name="dob" id="regDob"
                           class="form-input" required />
                </div>
            </div>

            <div class="form-field">
                <label class="form-label" for="regProgram">Program</label>
                <select name="programId" id="regProgram" class="form-select" required>
                    <option value="" disabled selected>— Select Program —</option>
                    <option value="1">BS Computer Science (BSCS)</option>
                    <option value="2">BS Software Engineering (BSSE)</option>
                    <option value="3">BS Electrical Engineering (BSEE)</option>
                </select>
            </div>

            <div class="form-field">
                <label class="form-label" for="regPassword">Password</label>
                <div class="password-field-wrap">
                    <input type="password" name="password" id="regPassword"
                           class="form-input"
                           placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;"
                           required />
                    <button type="button"
                            class="pwd-toggle"
                            onclick="togglePwd('regPassword', 'regEyeIcon')"
                            aria-label="Toggle password visibility">
                        <i class="bi bi-eye" id="regEyeIcon"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-primary-yellow auth-submit-btn" id="createAccountBtn">
                Create Account
            </button>
        </form>

        <p class="auth-footer-text" style="margin-top: 20px;">
            Already have an account?&nbsp;
            <a asp-controller="Auth" asp-action="Login" class="auth-link">Sign In &rarr;</a>
        </p>

    </div>
</div>

<style>
    /* Shared auth styles (these mirror login.cshtml styles) */
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        background: var(--clr-black);
    }

    .auth-card {
        width: 100%;
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: 2px;
        padding: 40px 36px;
    }

    .auth-logo {
        font-family: 'Inter', sans-serif;
        font-weight: 800;
        font-size: 18px;
        letter-spacing: -0.04em;
        color: var(--clr-yellow);
        text-align: center;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3px;
    }

    .auth-logo-dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        background: var(--clr-red);
        border-radius: 50%;
    }

    .auth-heading {
        font-size: 30px;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--clr-white);
        margin-bottom: 6px;
    }

    .auth-sub {
        font-size: 14px;
        color: var(--clr-muted);
        margin-bottom: 24px;
    }

    .auth-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 14px;
        font-size: 13px;
        margin-bottom: 18px;
        border-radius: 2px;
    }

    .auth-alert-error {
        background: var(--clr-surface);
        border-left: 3px solid var(--clr-red);
        color: var(--clr-text);
    }

    .auth-alert-icon {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 700;
        font-size: 12px;
        color: var(--clr-red);
        flex-shrink: 0;
        margin-top: 1px;
    }

    /* Two-column row for registration fields */
    .reg-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .password-field-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .password-field-wrap .form-input {
        padding-right: 44px !important;
    }

    .pwd-toggle {
        position: absolute;
        right: 12px;
        background: none;
        border: none;
        color: var(--clr-muted);
        cursor: pointer;
        font-size: 15px;
        padding: 4px;
        transition: color 0.15s ease;
        display: flex;
        align-items: center;
    }

    .pwd-toggle:hover { color: var(--clr-text); }

    .auth-submit-btn {
        width: 100%;
        padding: 13px 20px;
        font-size: 15px;
        font-weight: 700;
        margin-top: 4px;
        letter-spacing: 0.01em;
    }

    .auth-footer-text {
        text-align: center;
        font-size: 13px;
        color: var(--clr-muted);
        margin-bottom: 0;
    }

    .auth-link {
        color: var(--clr-yellow);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.15s ease;
    }

    .auth-link:hover { color: var(--clr-yellow-dim); }

    @@media (max-width: 560px) {
        .auth-card { padding: 28px 20px; }
        .auth-heading { font-size: 24px; }
        .reg-row { grid-template-columns: 1fr; gap: 0; }
    }
</style>

<script>
    function togglePwd(inputId, iconId) {
        var pwd = document.getElementById(inputId);
        var icon = document.getElementById(iconId);
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            pwd.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }
</script>
