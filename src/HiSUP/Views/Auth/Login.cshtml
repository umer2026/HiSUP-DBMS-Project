@{
    ViewData["Title"] = "Login";
}
<div class="row justify-content-center align-items-center py-5">
    <div class="col-md-5">
        <div class="card glass-card p-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;">Welcome Back</h2>
                <p class="text-muted">Sign in to access your HiSUP account</p>
            </div>

            <form asp-controller="Auth" asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-4">
                    <label class="form-label text-light fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-secondary text-secondary"><i
                            class="bi bi-envelope"></i></span>
                            <input type="email" name="email" class="form-control bg-transparent text-light border-secondary"
                                   placeholder="name@hitec.edu.pk" required />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-light fw-semibold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-secondary text-secondary"><i
                                class="bi bi-lock"></i></span>
                                <input type="password" name="password"
                                       class="form-control bg-transparent text-light border-secondary" placeholder="••••••••"
                                       required />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-gradient w-100 py-3 mt-2"><i
                            class="bi bi-box-arrow-in-right me-2"></i>Sign In</button>
                        </form>
                        <div class="text-center mt-4">
                            <p class="text-secondary mb-0">Don't have an account? <a asp-controller="Auth" asp-action="Register"
                                                                                         class="text-info fw-semibold text-decoration-none">Register here</a></p>
                            </div>
                        </div>
                    </div>
                </div>
