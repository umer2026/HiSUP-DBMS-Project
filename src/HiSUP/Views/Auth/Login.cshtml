@{
    ViewData["Title"] = "Sign In — HiSUP";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card" id="roleCard">

        <!-- Logotype -->
        <div class="auth-logo" aria-label="HiSUP">
            HiSUP<span class="auth-logo-dot" aria-hidden="true"></span>
        </div>

        <!-- ===== STEP 1: Role Selection ===== -->
        <div id="stepRole">
            <h1 class="auth-heading">Sign In</h1>
            <p class="auth-sub">Select your role to continue.</p>

            @if (TempData["Error"] != null)
            {
                <div class="auth-alert auth-alert-error" role="alert">
                    <span class="auth-alert-icon">✕</span>
                    <span>@TempData["Error"]</span>
                </div>
            }

            <div class="role-list" role="list">
                <button class="role-item" id="roleStudent"
                        onclick="selectRole('Student', 'Courses, grades, fees &amp; more')"
                        type="button" role="listitem">
                    <span class="role-item-label mono">STUDENT</span>
                    <span class="role-item-desc">Courses, grades, fees &amp; more</span>
                    <span class="role-item-arrow" aria-hidden="true">&rarr;</span>
                </button>

                <button class="role-item" id="roleFaculty"
                        onclick="selectRole('Faculty', 'Teaching, grading &amp; attendance')"
                        type="button" role="listitem">
                    <span class="role-item-label mono">FACULTY</span>
                    <span class="role-item-desc">Teaching, grading &amp; attendance</span>
                    <span class="role-item-arrow" aria-hidden="true">&rarr;</span>
                </button>

                <button class="role-item" id="roleAdmin"
                        onclick="selectRole('Admin', 'System oversight &amp; management')"
                        type="button" role="listitem">
                    <span class="role-item-label mono">ADMIN</span>
                    <span class="role-item-desc">System oversight &amp; management</span>
                    <span class="role-item-arrow" aria-hidden="true">&rarr;</span>
                </button>

                <button class="role-item" id="roleFinance"
                        onclick="selectRole('Finance', 'Fee management &amp; reporting')"
                        type="button" role="listitem">
                    <span class="role-item-label mono">FINANCE</span>
                    <span class="role-item-desc">Fee management &amp; reporting</span>
                    <span class="role-item-arrow" aria-hidden="true">&rarr;</span>
                </button>

                <button class="role-item" id="roleLibrarian"
                        onclick="selectRole('Librarian', 'Library &amp; circulation')"
                        type="button" role="listitem">
                    <span class="role-item-label mono">LIBRARIAN</span>
                    <span class="role-item-desc">Library &amp; circulation</span>
                    <span class="role-item-arrow" aria-hidden="true">&rarr;</span>
                </button>
            </div>

            <p class="auth-footer-text">
                Don't have an account?&nbsp;
                <a asp-controller="Auth" asp-action="Register" class="auth-link">Register &rarr;</a>
            </p>
        </div>

        <!-- ===== STEP 2: Email / Password ===== -->
        <div id="stepLogin" style="display:none;">

            <button class="auth-back-btn" onclick="goBack()" type="button" aria-label="Go back to role selection">
                &larr; Back
            </button>

            <!-- Selected role indicator -->
            <div class="selected-role-indicator" id="selectedRoleIndicator">
                <span class="badge-role" id="selectedRoleText">STUDENT</span>
            </div>

            <h1 class="auth-heading" style="margin-top:16px;">Sign In</h1>
            <p class="auth-sub" id="loginSubText">Access your university portal.</p>

            @if (!ViewContext.ModelState.IsValid)
            {
                <div class="auth-alert auth-alert-error" role="alert">
                    <span class="auth-alert-icon">✕</span>
                    <span>Invalid email or password. Please try again.</span>
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="role" id="hiddenRole" value="" />

                <div class="form-field">
                    <label class="form-label" for="loginEmail">Email Address</label>
                    <input type="email"
                           name="email"
                           id="loginEmail"
                           class="form-input"
                           placeholder="name@hitec.edu.pk"
                           required
                           autofocus />
                </div>

                <div class="form-field">
                    <label class="form-label" for="loginPassword">Password</label>
                    <div class="password-field-wrap">
                        <input type="password"
                               name="password"
                               id="loginPassword"
                               class="form-input"
                               placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;"
                               required />
                        <button type="button"
                                class="pwd-toggle"
                                onclick="togglePwd('loginPassword', 'pwdEyeIcon')"
                                aria-label="Toggle password visibility">
                            <i class="bi bi-eye" id="pwdEyeIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-primary-yellow auth-submit-btn" id="signInBtn">
                    Sign In
                </button>
            </form>

            <p class="auth-footer-text" style="margin-top: 20px;">
                Don't have an account?&nbsp;
                <a asp-controller="Auth" asp-action="Register" class="auth-link">Register &rarr;</a>
            </p>
        </div>

    </div>
</div>

<style>
    /* ---- Auth page layout ---- */
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        background: var(--clr-black);
    }

    .auth-card {
        width: 100%;
        max-width: 440px;
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: 2px;
        padding: 40px 36px;
    }

    /* Logo */
    .auth-logo {
        font-family: 'Inter', sans-serif;
        font-weight: 800;
        font-size: 18px;
        letter-spacing: -0.04em;
        color: var(--clr-yellow);
        text-align: center;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3px;
    }

    .auth-logo-dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        background: var(--clr-red);
        border-radius: 50%;
    }

    /* Headings */
    .auth-heading {
        font-size: 30px;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--clr-white);
        margin-bottom: 6px;
    }

    .auth-sub {
        font-size: 14px;
        color: var(--clr-muted);
        margin-bottom: 24px;
    }

    /* Alerts */
    .auth-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 10px 14px;
        font-size: 13px;
        margin-bottom: 18px;
        border-radius: 2px;
    }

    .auth-alert-error {
        background: var(--clr-surface);
        border-left: 3px solid var(--clr-red);
        color: var(--clr-text);
    }

    .auth-alert-icon {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 700;
        font-size: 12px;
        color: var(--clr-red);
        flex-shrink: 0;
        margin-top: 1px;
    }

    /* Role list */
    .role-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 24px;
    }

    .role-item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: transparent;
        border: 1px solid var(--clr-border);
        border-radius: 2px;
        padding: 14px 16px;
        cursor: pointer;
        text-align: left;
        width: 100%;
        transition: border-color 0.15s ease, background 0.15s ease;
    }

    .role-item:hover {
        border-color: var(--clr-yellow);
        background: #141414;
    }

    .role-item-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        color: var(--clr-yellow);
        flex-shrink: 0;
        width: 80px;
    }

    .role-item-desc {
        font-size: 13px;
        color: var(--clr-muted);
        flex: 1;
    }

    .role-item-arrow {
        color: var(--clr-border);
        font-size: 14px;
        flex-shrink: 0;
        transition: color 0.15s ease;
    }

    .role-item:hover .role-item-arrow { color: var(--clr-yellow); }

    /* Selected role indicator */
    .selected-role-indicator {
        margin-bottom: 4px;
    }

    /* Back button */
    .auth-back-btn {
        background: none;
        border: none;
        color: var(--clr-muted);
        font-size: 13px;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        padding: 0;
        margin-bottom: 16px;
        transition: color 0.15s ease;
    }

    .auth-back-btn:hover { color: var(--clr-text); }

    /* Password field wrapper */
    .password-field-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .password-field-wrap .form-input {
        padding-right: 44px !important;
    }

    .pwd-toggle {
        position: absolute;
        right: 12px;
        background: none;
        border: none;
        color: var(--clr-muted);
        cursor: pointer;
        font-size: 15px;
        padding: 4px;
        transition: color 0.15s ease;
        display: flex;
        align-items: center;
    }

    .pwd-toggle:hover { color: var(--clr-text); }

    /* Submit button */
    .auth-submit-btn {
        width: 100%;
        padding: 13px 20px;
        font-size: 15px;
        font-weight: 700;
        margin-top: 4px;
        letter-spacing: 0.01em;
    }

    /* Footer text */
    .auth-footer-text {
        text-align: center;
        font-size: 13px;
        color: var(--clr-muted);
        margin-bottom: 0;
    }

    .auth-link {
        color: var(--clr-yellow);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.15s ease;
    }

    .auth-link:hover { color: var(--clr-yellow-dim); }

    @@media (max-width: 480px) {
        .auth-card { padding: 28px 20px; }
        .auth-heading { font-size: 24px; }
    }
</style>

<script>
    function selectRole(role, desc) {
        document.getElementById('hiddenRole').value = role;
        document.getElementById('selectedRoleText').textContent = role.toUpperCase();
        document.getElementById('loginSubText').textContent = 'Enter your ' + role.toLowerCase() + ' credentials to continue.';

        document.getElementById('stepRole').style.display = 'none';
        var loginStep = document.getElementById('stepLogin');
        loginStep.style.display = 'block';

        setTimeout(function () {
            var emailField = loginStep.querySelector('#loginEmail');
            if (emailField) emailField.focus();
        }, 80);
    }

    function goBack() {
        document.getElementById('stepLogin').style.display = 'none';
        document.getElementById('stepRole').style.display = 'block';
    }

    function togglePwd(inputId, iconId) {
        var pwd = document.getElementById(inputId);
        var icon = document.getElementById(iconId);
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            pwd.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    // If model state invalid (validation error), jump straight to login step
    @if (!ViewContext.ModelState.IsValid)
    {
        <text>
        document.getElementById('stepRole').style.display = 'none';
        document.getElementById('stepLogin').style.display = 'block';
        </text>
    }
</script>
