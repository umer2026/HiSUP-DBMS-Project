@model List<HiSUP.Models.LibraryItem>
@{
    ViewData["Title"] = "Library Catalog — HiSUP";
    string search = ViewBag.SearchTerm as string;
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">LIBRARY / CATALOG</span>
        <h1 class="page-title">Library Catalog</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Full-text search using SQL Server <span class="mono">CONTAINS</span> / <span class="mono">FREETEXT</span> across title and author columns.
        </p>
    </div>

    <div class="page-body">

        <!-- Search Bar -->
        <div class="filter-panel mb-4">
            <form method="get" asp-action="Index" id="librarySearchForm">
                <div style="display:flex; gap:8px; align-items:stretch;">
                    <input type="text"
                           name="search"
                           id="librarySearch"
                           class="form-input"
                           placeholder="Search by title, author, ISBN, or keyword..."
                           value="@search"
                           style="flex:1; font-size:15px;" />
                    <button class="btn-primary-yellow" type="submit" id="librarySearchBtn"
                            style="padding:10px 28px; font-size:14px; white-space:nowrap;">
                        Search
                    </button>
                    @if (!string.IsNullOrEmpty(search))
                    {
                        <a asp-action="Index" class="btn-ghost" style="padding:10px 16px; font-size:13px;">Clear</a>
                    }
                </div>
                <p style="font-size:12px; color:var(--clr-muted); margin-top:8px; font-family:var(--font-mono);">
                    Searches across Title and Author columns simultaneously via Full-Text Search.
                </p>
            </form>
        </div>

        <!-- Stats -->
        @if (Model != null)
        {
            <div class="row g-2 mb-4">
                <div class="col-md-4">
                    <div class="stat-card-dark">
                        <span class="stat-card-title">@(string.IsNullOrEmpty(search) ? "Total Catalog Items" : "Search Results")</span>
                        <span class="stat-card-value">@Model.Count</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card-dark">
                        <span class="stat-card-title">Available Items</span>
                        <span class="stat-card-value">@Model.Count(i => i.CopiesAvailable > 0)</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card-dark" style="border-left-color:var(--clr-red);">
                        <span class="stat-card-title">Fully Checked Out</span>
                        <span class="stat-card-value" style="color:@(Model.Count(i => i.CopiesAvailable == 0) > 0 ? "var(--clr-red)" : "var(--clr-white)");">
                            @Model.Count(i => i.CopiesAvailable == 0)
                        </span>
                    </div>
                </div>
            </div>
        }

        <!-- Results -->
        @if (!string.IsNullOrEmpty(search) && (Model == null || !Model.Any()))
        {
            <div class="portal-table-wrap" style="padding:48px; text-align:center;">
                <p style="color:var(--clr-muted); font-size:14px;">
                    No items found for "<strong style="color:var(--clr-text);">@search</strong>".
                    Try different keywords or check the spelling.
                </p>
            </div>
        }
        else if (Model != null && Model.Any())
        {
            <div class="row g-2" id="libraryResults">
                @foreach (var item in Model)
                {
                    <div class="col-md-4">
                        <div class="card-dark" style="height:100%; display:flex; flex-direction:column;">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                                <span class="badge-role" style="font-size:9px;">@item.Type</span>
                                <span class="mono" style="font-size:11px; color:var(--clr-muted);">@item.Location</span>
                            </div>
                            <h3 style="font-size:15px; font-weight:700; color:var(--clr-white); margin-bottom:4px; letter-spacing:-0.01em;">
                                @item.Title
                            </h3>
                            <p style="font-size:13px; color:var(--clr-muted); margin-bottom:0; flex:1;">
                                By <em>@item.Author</em>
                            </p>
                            <div style="margin-top:16px; padding-top:12px; border-top:1px solid var(--clr-border); display:flex; justify-content:space-between; align-items:center;">
                                <span class="mono" style="font-size:11px; color:var(--clr-muted);">@item.ISBN</span>
                                <span class="status-badge @(item.CopiesAvailable > 0 ? "status-active" : "status-danger")">
                                    @item.CopiesAvailable / @item.TotalCopies available
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="portal-table-wrap" style="padding:64px; text-align:center;">
                <p style="color:var(--clr-muted); font-size:14px;">Enter a keyword above to search the library catalog.</p>
            </div>
        }

    </div>
</div>
