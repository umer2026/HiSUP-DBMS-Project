@model List<HiSUP.Controllers.vw_FeeDefaultersDto>
@{
    ViewData["Title"] = "Fee Defaulters";
}
<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;"><i
            class="bi bi-exclamation-triangle text-danger me-2"></i>Fee Defaulters List</h2>
            <p class="text-muted">Displays a list of students with outstanding fee balances, loaded dynamically from
                `vw_FeeDefaulters` view.</p>
            </div>
        </div>
        <div class="card glass-card p-4">
            <div class="table-responsive">
                <table class="table table-dark table-hover border-secondary align-middle">
                    <thead>
                        <tr>
                            <th>StudentID</th>
                            <th>Student Name</th>
                            <th>Email</th>
                            <th>Program</th>
                            <th>Current Semester</th>
                            <th class="text-end">Outstanding Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-secondary py-4">No students are currently defaulting on
                                    fees. All balances cleared!</td>
                                </tr>
                            }
                else
                            {
                                foreach (var s in Model)
                                {
                                    <tr>
                                        <td>@s.StudentID</td>
                                        <td class="text-light fw-semibold">@s.FirstName @s.LastName</td>
                                        <td>@s.Email</td>
                                        <td>@s.ProgramName</td>
                                        <td>Semester @s.CurrentSemester</td>
                                        <td class="text-end text-danger fw-bold fs-5">Rs. @s.OutstandingAmount.ToString("N2")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
