@model List<HiSUP.Controllers.vw_FeeDefaultersDto>
@{
    ViewData["Title"] = "Fee Defaulters — HiSUP";
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">FINANCE / DEFAULTERS</span>
        <h1 class="page-title">Fee Defaulters</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Students with outstanding fee balances — loaded from <span class="mono">vw_FeeDefaulters</span> view.
        </p>
    </div>

    <div class="page-body">

        @if (Model != null && Model.Any())
        {
            <div class="alert-error-portal" style="margin-bottom:20px;">
                @Model.Count student(s) have outstanding fee balances. Immediate action may be required.
            </div>
        }

        <div class="portal-table-wrap">
            <div class="portal-table-head">
                <span class="portal-table-head-title">Defaulters List</span>
                @if (Model != null)
                {
                    <span class="badge-role" style="border-color:var(--clr-red); color:var(--clr-red);">@Model.Count DEFAULTERS</span>
                }
            </div>
            <div class="table-responsive">
                <table class="portal-table" id="defaultersTable">
                    <thead>
                        <tr>
                            <th style="padding-left:24px;">Student ID</th>
                            <th>Student Name</th>
                            <th>Email</th>
                            <th>Program</th>
                            <th>Semester</th>
                            <th style="text-align:right; padding-right:24px;">Outstanding Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                    No students are currently defaulting on fees. All balances cleared.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var s in Model)
                            {
                                <tr class="row-danger">
                                    <td style="padding-left:24px;" class="mono" style="font-size:12px; color:var(--clr-muted);">@s.StudentID</td>
                                    <td style="font-weight:700; color:var(--clr-white);">@s.FirstName @s.LastName</td>
                                    <td class="mono" style="font-size:12px; color:var(--clr-muted);">@s.Email</td>
                                    <td style="font-size:13px; color:var(--clr-text);">@s.ProgramName</td>
                                    <td class="mono" style="font-size:12px; color:var(--clr-muted);">SEM @s.CurrentSemester</td>
                                    <td style="text-align:right; padding-right:24px; font-weight:700; font-family:var(--font-mono); color:var(--clr-red); font-size:15px;">
                                        Rs. @s.OutstandingAmount.ToString("N2")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>
