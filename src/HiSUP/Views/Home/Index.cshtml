@{
    ViewData["Title"] = "HITEC Smart University Portal — HiSUP";
}

<!-- ========== HERO SECTION ========== -->
<section class="landing-hero" id="home">
    <div class="hero-inner">

        <!-- LEFT: Headline + CTA -->
        <div class="hero-left">
            <p class="section-label">HITEC UNIVERSITY · TAXILA</p>
            <h1 class="hero-headline">
                <span class="hero-line-1">SMART PORTAL</span>
                <span class="hero-line-2">FOR HITEC UNIVERSITY</span>
            </h1>
            <p class="hero-desc">
                Manage academics, fees, library, and attendance — all in one place.
            </p>
            @if (!User.Identity!.IsAuthenticated)
            {
                <a asp-controller="Auth" asp-action="Login" class="hero-cta btn-ghost" id="heroAccessBtn">
                    Access Portal &rarr;
                </a>
            }
            else
            {
                <a href="#portals" class="hero-cta btn-ghost" id="heroPortalBtn">
                    My Portal &rarr;
                </a>
            }
        </div>

        <!-- RIGHT: System list with yellow left-border -->
        <div class="hero-right" aria-label="University systems">
            <div class="hero-system-list">
                <div class="hero-system-item">
                    <span class="mono hero-system-label">ACADEMICS</span>
                    <span class="hero-system-sub">Courses · Grades · Transcripts</span>
                </div>
                <div class="hero-system-item">
                    <span class="mono hero-system-label">FINANCE</span>
                    <span class="hero-system-sub">Fee Management · Payments · Defaulters</span>
                </div>
                <div class="hero-system-item">
                    <span class="mono hero-system-label">LIBRARY</span>
                    <span class="hero-system-sub">Full-Text Search · Catalog · Circulation</span>
                </div>
                <div class="hero-system-item">
                    <span class="mono hero-system-label">ATTENDANCE</span>
                    <span class="hero-system-sub">Section-level Tracking · Reports</span>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- ========== STATS BAR ========== -->
<section class="stats-bar" aria-label="University statistics">
    <div class="stats-inner">
        <div class="stat-item">
            <span class="stat-number mono">2,400+</span>
            <span class="stat-label section-label">STUDENTS</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
            <span class="stat-number mono">180+</span>
            <span class="stat-label section-label">FACULTY</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
            <span class="stat-number mono">12</span>
            <span class="stat-label section-label">DEPTS</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
            <span class="stat-number mono">99.8%</span>
            <span class="stat-label section-label">UPTIME</span>
        </div>
    </div>
</section>

<!-- ========== FEATURES SECTION ========== -->
<section class="features-section" id="features">
    <div class="features-inner">
        <div class="features-header">
            <p class="section-label">CAPABILITIES</p>
            <h2 class="features-title">What HiSUP Manages</h2>
        </div>
        <div class="features-grid">

            <div class="feature-card card-dark">
                <div class="feature-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                    </svg>
                </div>
                <h3 class="feature-title">Academic Management</h3>
                <p class="feature-desc">Course registration, grade entry, CGPA tracking, and full academic transcript generation via SQL views.</p>
            </div>

            <div class="feature-card card-dark">
                <div class="feature-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                        <line x1="2" y1="10" x2="22" y2="10"></line>
                    </svg>
                </div>
                <h3 class="feature-title">Fee &amp; Finance</h3>
                <p class="feature-desc">Secure fee submission, payment approvals, defaulter identification, and revenue analytics via stored procedures.</p>
            </div>

            <div class="feature-card card-dark">
                <div class="feature-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                </div>
                <h3 class="feature-title">Library Search</h3>
                <p class="feature-desc">SQL Server full-text search across title and author columns simultaneously. Real-time catalog with availability tracking.</p>
            </div>

        </div>
    </div>
</section>

<!-- ========== PORTALS SECTION ========== -->
<section class="portals-section" id="portals">
    <div class="portals-inner">
        <div class="portals-header">
            <p class="section-label">ACCESS CONTROL</p>
            <h2 class="portals-title">Choose Your Gateway</h2>
        </div>
        <div class="portals-grid">

            <a asp-controller="Admin" asp-action="Index" class="portal-entry" id="portalAdmin">
                <span class="portal-role section-label">ADMIN</span>
                <span class="portal-name">Administration Panel</span>
                <span class="portal-detail">System oversight, user management, course approvals &amp; audit logs</span>
                <span class="portal-arrow">&rarr;</span>
            </a>

            <a asp-controller="Student" asp-action="Index" class="portal-entry" id="portalStudent">
                <span class="portal-role section-label">STUDENT</span>
                <span class="portal-name">Student Portal</span>
                <span class="portal-detail">Courses, grades, fee management &amp; library access</span>
                <span class="portal-arrow">&rarr;</span>
            </a>

            <a asp-controller="Faculty" asp-action="Index" class="portal-entry" id="portalFaculty">
                <span class="portal-role section-label">FACULTY</span>
                <span class="portal-name">Faculty Dashboard</span>
                <span class="portal-detail">Timetable, grading &amp; attendance tracking</span>
                <span class="portal-arrow">&rarr;</span>
            </a>

            <a asp-controller="Finance" asp-action="Index" class="portal-entry" id="portalFinance">
                <span class="portal-role section-label">FINANCE</span>
                <span class="portal-name">Finance Office</span>
                <span class="portal-detail">Collections, pending approvals &amp; defaulters report</span>
                <span class="portal-arrow">&rarr;</span>
            </a>

        </div>
    </div>
</section>

<!-- ========== ABOUT SECTION ========== -->
<section class="about-section" id="about">
    <div class="about-inner">
        <div class="about-header">
            <p class="section-label">ABOUT THE INSTITUTION</p>
            <h2 class="about-title">HITEC University, Taxila</h2>
            <p class="about-desc">
                Located in the historic city of Taxila — one of the world's oldest centers of learning —
                HITEC University stands at the intersection of a rich intellectual heritage and a dynamic
                industrial ecosystem. Our close association with Heavy Industries Taxila (HIT) provides
                a distinctive advantage, integrating academic knowledge with industrial expertise.
            </p>
        </div>
        <div class="about-grid">
            <div class="about-info-card card-dark">
                <span class="stat-card-title">Vision</span>
                <p style="font-size:14px; color: var(--clr-muted); line-height: 1.65;">
                    To be a premier institution achieving academic excellence through innovative solutions,
                    in collaboration with industry, for sustainable development and socio-economic growth.
                </p>
            </div>
            <div class="about-info-card card-dark">
                <span class="stat-card-title">Mission</span>
                <p style="font-size:14px; color: var(--clr-muted); line-height: 1.65;">
                    To impart quality education by equipping students with knowledge, research, creativity
                    and entrepreneurial skills to compete in the local and global market.
                </p>
            </div>
            <div class="about-info-card card-dark">
                <span class="stat-card-title">Contact</span>
                <p class="mono" style="font-size:12px; color: var(--clr-muted); line-height: 1.8;">
                    HITEC University, Taxila Cantt<br />
                    Rawalpindi, Punjab 47080<br />
                    +92-51-4908500-18<br />
                    info@hitecuni.edu.pk
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    /* ---- Hero ---- */
    .landing-hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        border-bottom: 1px solid var(--clr-border);
        padding: 80px 0 40px;
    }

    .hero-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
        display: grid;
        grid-template-columns: 3fr 2fr;
        gap: 80px;
        align-items: center;
        width: 100%;
    }

    .hero-headline {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin: 16px 0 20px;
    }

    .hero-line-1 {
        font-family: 'Inter', sans-serif;
        font-size: clamp(44px, 7vw, 76px);
        font-weight: 900;
        letter-spacing: -0.04em;
        color: var(--clr-white);
        line-height: 1;
        display: block;
    }

    .hero-line-2 {
        font-family: 'Inter', sans-serif;
        font-size: clamp(20px, 3vw, 34px);
        font-weight: 400;
        letter-spacing: -0.01em;
        color: var(--clr-yellow);
        line-height: 1.2;
        display: block;
    }

    .hero-desc {
        font-size: 15px;
        color: var(--clr-muted);
        line-height: 1.65;
        max-width: 480px;
        margin-bottom: 32px;
    }

    .hero-cta {
        font-size: 15px;
        font-weight: 700;
        padding: 14px 28px;
        letter-spacing: 0.01em;
    }

    /* Hero Right — system list */
    .hero-right {
        padding-left: 40px;
        border-left: 1px solid var(--clr-border);
    }

    .hero-system-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .hero-system-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 20px 0 20px 20px;
        border-left: 3px solid var(--clr-yellow);
        margin-bottom: 16px;
    }

    .hero-system-label {
        font-size: 13px;
        font-weight: 700;
        color: var(--clr-text);
        letter-spacing: 0.12em;
    }

    .hero-system-sub {
        font-size: 12px;
        color: var(--clr-muted);
        font-family: 'JetBrains Mono', monospace;
    }

    /* ---- Stats Bar ---- */
    .stats-bar {
        background: var(--clr-black);
        border-bottom: 1px solid var(--clr-border);
        padding: 0;
    }

    .stats-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
        display: flex;
        align-items: stretch;
    }

    .stat-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px 24px;
        gap: 6px;
        text-align: center;
    }

    .stat-number {
        font-family: 'Inter', sans-serif;
        font-size: clamp(24px, 3.5vw, 40px);
        font-weight: 800;
        color: var(--clr-yellow);
        letter-spacing: -0.03em;
        line-height: 1;
    }

    .stat-label {
        font-size: 10px;
        letter-spacing: 0.15em;
        margin-bottom: 0;
    }

    .stat-divider {
        width: 1px;
        background: var(--clr-border);
        align-self: stretch;
        flex-shrink: 0;
    }

    /* ---- Features ---- */
    .features-section {
        padding: 80px 0;
        border-bottom: 1px solid var(--clr-border);
    }

    .features-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .features-header { margin-bottom: 40px; }

    .features-title {
        font-size: clamp(22px, 3vw, 32px);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--clr-white);
        margin-top: 6px;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
    }

    .feature-card {
        padding: 28px 24px;
    }

    .feature-icon {
        color: var(--clr-yellow);
        margin-bottom: 16px;
    }

    .feature-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--clr-white);
        margin-bottom: 8px;
        letter-spacing: -0.01em;
    }

    .feature-desc {
        font-size: 13px;
        color: var(--clr-muted);
        line-height: 1.65;
    }

    /* ---- Portals ---- */
    .portals-section {
        padding: 80px 0;
        border-bottom: 1px solid var(--clr-border);
    }

    .portals-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .portals-header { margin-bottom: 40px; }

    .portals-title {
        font-size: clamp(22px, 3vw, 32px);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--clr-white);
        margin-top: 6px;
    }

    .portals-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2px;
    }

    .portal-entry {
        display: flex;
        flex-direction: column;
        gap: 6px;
        background: var(--clr-surface);
        border: 1px solid var(--clr-border);
        border-radius: 2px;
        padding: 24px 20px;
        text-decoration: none;
        transition: border-color 0.15s ease, background 0.15s ease;
    }

    .portal-entry:hover {
        border-color: var(--clr-yellow);
        background: #141414;
        color: inherit;
    }

    .portal-entry:hover .portal-arrow {
        color: var(--clr-yellow);
    }

    .portal-role { font-size: 10px; }

    .portal-name {
        font-size: 16px;
        font-weight: 700;
        color: var(--clr-white);
        letter-spacing: -0.01em;
    }

    .portal-detail {
        font-size: 12px;
        color: var(--clr-muted);
        line-height: 1.55;
        flex: 1;
    }

    .portal-arrow {
        font-size: 18px;
        color: var(--clr-border);
        margin-top: 8px;
        transition: color 0.15s ease;
    }

    /* ---- About ---- */
    .about-section {
        padding: 80px 0;
    }

    .about-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .about-header {
        margin-bottom: 40px;
        max-width: 640px;
    }

    .about-title {
        font-size: clamp(22px, 3vw, 32px);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-top: 6px;
        margin-bottom: 16px;
    }

    .about-desc {
        font-size: 14px;
        color: var(--clr-muted);
        line-height: 1.7;
    }

    .about-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
    }

    .about-info-card { padding: 24px; }

    /* ---- Responsive ---- */
    @@media (max-width: 1100px) {
        .hero-inner { grid-template-columns: 1fr; gap: 48px; }
        .hero-right { padding-left: 0; border-left: none; border-top: 1px solid var(--clr-border); padding-top: 40px; }
        .portals-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 767px) {
        .landing-hero { padding: 60px 0 40px; }
        .hero-inner { padding: 0 20px; gap: 32px; }
        .features-inner, .portals-inner, .about-inner, .stats-inner { padding: 0 20px; }
        .features-section, .portals-section, .about-section { padding: 56px 0; }
        .features-grid { grid-template-columns: 1fr; }
        .portals-grid { grid-template-columns: 1fr; }
        .about-grid { grid-template-columns: 1fr; }
        .stat-item { padding: 24px 12px; }
    }
</style>
