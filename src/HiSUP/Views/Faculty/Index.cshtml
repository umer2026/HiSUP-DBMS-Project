@model List<HiSUP.Controllers.vw_FacultyCourseLoadDto>
@{
    ViewData["Title"] = "Faculty Dashboard — HiSUP";
    var faculty = Model != null && Model.Count > 0 ? Model[0] : null;
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">FACULTY / DASHBOARD</span>
        <h1 class="page-title">
            @if (faculty != null)
            {
                @($"{faculty.FirstName} {faculty.LastName}")
            }
            else
            {
                @:Faculty Dashboard
            }
        </h1>
        @if (faculty != null)
        {
            <p style="font-size:13px; color:var(--clr-muted); margin-top:6px; font-family:var(--font-mono);">
                @faculty.Designation
            </p>
        }
    </div>

    <div class="page-body">

        <!-- Summary Stats -->
        @if (Model != null && Model.Count > 0)
        {
            <div class="row g-2 mb-4">
                <div class="col-md-4">
                    <div class="stat-card-dark">
                        <span class="stat-card-title">Sections Assigned</span>
                        <span class="stat-card-value">@Model.Count</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card-dark">
                        <span class="stat-card-title">Total Students Enrolled</span>
                        <span class="stat-card-value">@Model.Sum(m => m.EnrolledCount)</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card-dark">
                        <span class="stat-card-title">Designation</span>
                        <span class="stat-card-value" style="font-size:18px;">@faculty?.Designation</span>
                    </div>
                </div>
            </div>
        }

        <!-- Assigned Sections Table -->
        <div class="portal-table-wrap">
            <div class="portal-table-head">
                <span class="portal-table-head-title">My Assigned Sections</span>
                <span class="section-label" style="margin-bottom:0;">vw_FacultyCourseLoad</span>
            </div>
            <div class="table-responsive">
                <table class="portal-table" id="sectionsTable">
                    <thead>
                        <tr>
                            <th style="padding-left:24px;">Section</th>
                            <th>Course</th>
                            <th>Semester / Year</th>
                            <th>Room</th>
                            <th>Enrollment</th>
                            <th style="text-align:right; padding-right:24px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                    No sections assigned yet.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var row in Model)
                            {
                                <tr>
                                    <td style="padding-left:24px; font-weight:700; color:var(--clr-white);" class="mono">
                                        @row.SectionName
                                    </td>
                                    <td>
                                        <span class="badge-role" style="font-size:9px; margin-right:6px;">@row.CourseCode</span>
                                        <span style="font-size:13px; color:var(--clr-text);">@row.CourseTitle</span>
                                    </td>
                                    <td class="mono" style="font-size:12px; color:var(--clr-muted);">
                                        @row.Semester / @row.Year
                                    </td>
                                    <td style="font-size:13px; color:var(--clr-muted);">@row.RoomNo</td>
                                    <td>
                                        <div style="display:flex; align-items:center; gap:10px;">
                                            <div class="portal-progress" style="flex:1; margin-top:0;">
                                                <div class="portal-progress-bar bar-green"
                                                     style="width:@(row.Capacity > 0 ? (row.EnrolledCount * 100 / row.Capacity) : 0)%;"></div>
                                            </div>
                                            <span class="mono" style="font-size:11px; color:var(--clr-muted); white-space:nowrap;">
                                                @row.EnrolledCount / @row.Capacity
                                            </span>
                                        </div>
                                    </td>
                                    <td style="text-align:right; padding-right:24px;">
                                        <a asp-action="MarkAttendance" asp-route-sectionId="@row.SectionID"
                                           class="btn-ghost" style="font-size:12px; padding:6px 12px; margin-right:6px;">
                                            Attendance
                                        </a>
                                        <a asp-action="GradeEntry" asp-route-sectionId="@row.SectionID"
                                           class="btn-ghost" style="font-size:12px; padding:6px 12px;">
                                            Grades
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>
