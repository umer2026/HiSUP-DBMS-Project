@model List<HiSUP.Models.Enrollment>
@{
    ViewData["Title"] = "Mark Attendance — HiSUP";
    int sectionId = ViewBag.SectionID;
}

<div class="portal-page">

    <div class="page-header">
        <span class="section-label">FACULTY / ATTENDANCE</span>
        <h1 class="page-title">Mark Session Attendance — Section #@sectionId</h1>
        <p style="font-size:14px; color:var(--clr-muted); margin-top:4px;">
            Record student attendance statuses for the current session date.
        </p>
    </div>

    <div class="page-body">
        <form asp-action="SubmitAttendance" method="post" id="attendanceForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="sectionId" value="@sectionId" />

            <!-- Date selector -->
            <div class="filter-panel mb-4" style="max-width:320px;">
                <label class="form-label" for="attendanceDate">Attendance Date</label>
                <input type="date" name="date" id="attendanceDate"
                       class="form-input"
                       value="@DateTime.Now.ToString("yyyy-MM-dd")"
                       required />
            </div>

            <div class="portal-table-wrap mb-4">
                <div class="portal-table-head">
                    <span class="portal-table-head-title">Enrolled Students</span>
                    @if (Model != null)
                    {
                        <span class="badge-role">@Model.Count STUDENTS</span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="portal-table" id="attendanceTable">
                        <thead>
                            <tr>
                                <th style="padding-left:24px;">Student ID</th>
                                <th>Student Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th style="padding-right:24px;">Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="5" style="text-align:center; padding:48px 16px; color:var(--clr-muted); font-size:13px;">
                                        No enrolled students in this section.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                for (int i = 0; i < Model.Count; i++)
                                {
                                    var enrollment = Model[i];
                                    <tr>
                                        <td style="padding-left:24px;" class="mono" style="font-size:12px; color:var(--clr-muted);">@enrollment.StudentID</td>
                                        <td style="font-weight:600; color:var(--clr-white);">
                                            @enrollment.Student.FirstName @enrollment.Student.LastName
                                        </td>
                                        <td class="mono" style="font-size:12px; color:var(--clr-muted);">@enrollment.Student.Email</td>
                                        <td>
                                            <input type="hidden" name="attendanceList[@i].EnrollmentID" value="@enrollment.EnrollmentID" />
                                            <div class="att-radio-group" role="radiogroup" aria-label="Attendance status">
                                                <input type="radio" class="att-check" name="attendanceList[@i].Status" id="p_@i" value="P" checked>
                                                <label class="att-label att-present" for="p_@i">P</label>

                                                <input type="radio" class="att-check" name="attendanceList[@i].Status" id="a_@i" value="A">
                                                <label class="att-label att-absent" for="a_@i">A</label>

                                                <input type="radio" class="att-check" name="attendanceList[@i].Status" id="l_@i" value="L">
                                                <label class="att-label att-leave" for="l_@i">L</label>

                                                <input type="radio" class="att-check" name="attendanceList[@i].Status" id="e_@i" value="E">
                                                <label class="att-label att-excused" for="e_@i">E</label>
                                            </div>
                                        </td>
                                        <td style="padding-right:24px;">
                                            <input type="text" name="attendanceList[@i].Remarks"
                                                   class="form-input"
                                                   placeholder="Optional notes"
                                                   style="padding:7px 12px; font-size:13px;" />
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div style="display:flex; gap:12px; justify-content:flex-end;">
                    <a asp-action="Index" class="btn-ghost" style="padding:12px 24px;">Cancel</a>
                    <button type="submit" class="btn-primary-yellow" style="padding:12px 28px;" id="submitAttBtn">Submit Attendance</button>
                </div>
            }
        </form>
    </div>
</div>

<style>
    /* Attendance radio group */
    .att-radio-group { display: flex; gap: 4px; }

    .att-check { position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none; }

    .att-label {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 28px;
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        cursor: pointer;
        border: 1px solid var(--clr-border);
        border-radius: 2px;
        color: var(--clr-muted);
        transition: background 0.12s ease, color 0.12s ease, border-color 0.12s ease;
        user-select: none;
    }

    .att-check:checked + .att-present { background: rgba(76, 175, 80, 0.2); color: #6fcf6f; border-color: rgba(76, 175, 80, 0.5); }
    .att-check:checked + .att-absent  { background: rgba(214, 40, 40, 0.2); color: var(--clr-red); border-color: rgba(214, 40, 40, 0.5); }
    .att-check:checked + .att-leave   { background: rgba(245, 197, 24, 0.2); color: var(--clr-yellow); border-color: rgba(245, 197, 24, 0.5); }
    .att-check:checked + .att-excused { background: rgba(107, 107, 107, 0.2); color: var(--clr-muted); border-color: rgba(107, 107, 107, 0.4); }

    .att-label:hover { border-color: var(--clr-muted); color: var(--clr-text); }
</style>