@model List<HiSUP.Models.Enrollment>
@{
    ViewData["Title"] = "Mark Attendance";
    int sectionId = ViewBag.SectionID;
}
<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="fw-bold" style="font-family: 'Outfit', sans-serif;"><i class="bi bi-calendar-check text-primary me-2"></i>Mark Session Attendance</h2>
        <p class="text-muted">Record student attendance statuses for the current session date.</p>
    </div>
</div>
<form asp-action="SubmitAttendance" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="sectionId" value="@sectionId" />
    <div class="card glass-card p-4 mb-4">
        <div class="row align-items-center">
            <div class="col-md-4">
                <label class="form-label text-light fw-semibold">Attendance Date</label>
                <input type="date" name="date" class="form-control bg-transparent text-light border-secondary" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
            </div>
        </div>
    </div>
    <div class="card glass-card p-4 mb-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover border-secondary align-middle">
                <thead>
                    <tr>
                        <th>StudentID</th>
                        <th>Student Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-secondary py-4">No enrolled students in this section.</td>
                        </tr>
                    }
                    else
                    {
                        for (int i = 0; i < Model.Count; i++)
                        {
                            var enrollment = Model[i];
                            <tr>
                                <td>@enrollment.StudentID</td>
                                <td class="fw-semibold text-light">@enrollment.Student.FirstName @enrollment.Student.LastName</td>
                                <td>@enrollment.Student.Email</td>
                                <td>
                                    <input type="hidden" name="attendanceList[@i].EnrollmentID" value="@enrollment.EnrollmentID" />
                                    <div class="btn-group" role="group">
                                        <input type="radio" class="btn-check" name="attendanceList[@i].Status" id="p_@i" value="P" checked autocomplete="off">
                                        <label class="btn btn-outline-success btn-sm px-3" for="p_@i">P</label>
                                        <input type="radio" class="btn-check" name="attendanceList[@i].Status" id="a_@i" value="A" autocomplete="off">
                                        <label class="btn btn-outline-danger btn-sm px-3" for="a_@i">A</label>
                                        <input type="radio" class="btn-check" name="attendanceList[@i].Status" id="l_@i" value="L" autocomplete="off">
                                        <label class="btn btn-outline-warning btn-sm px-3" for="l_@i">L</label>
                                        <input type="radio" class="btn-check" name="attendanceList[@i].Status" id="e_@i" value="E" autocomplete="off">
                                        <label class="btn btn-outline-secondary btn-sm px-3" for="e_@i">E</label>
                                    </div>
                                </td>
                                <td>
                                    <input type="text" name="attendanceList[@i].Remarks" class="form-control bg-transparent text-light border-secondary form-control-sm" placeholder="Optional notes" />
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model != null && Model.Any())
    {
        <div class="text-end">
            <a asp-action="Index" class="btn btn-outline-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-gradient px-5">Submit Attendance</button>
        </div>
    }
</form>